// SamadhiRice.lk — database schema
// Postgres on Supabase. `prisma db push` for now; switch to pooled URL +
// Prisma Accelerate for serverless runtime on Vercel later.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD
  PAYHERE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model User {
  id              String         @id @default(cuid())
  name            String?
  email           String         @unique
  passwordHash    String?
  phone           String?
  role            Role           @default(CUSTOMER)
  emailVerified   DateTime?
  addresses       Address[]
  orders          Order[]
  reviews         Review[]
  notifications   Notification[]
  specialRequests SpecialRequest[]
  disabled        Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([email])
}

model Address {
  id        String  @id @default(cuid())
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  label     String?
  line1     String
  line2     String?
  city      String
  district  String?
  phone     String?
  isDefault Boolean @default(false)
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  products    Product[]
  createdAt   DateTime  @default(now())

  @@index([slug])
}

model Product {
  id              String      @id @default(cuid())
  name            String
  slug            String      @unique
  sinhala         String?
  variety         String?
  note            String? // short tasting note
  description     String? // long-form description
  origin          String?
  pricePerKg      Int // LKR
  stockKg         Int         @default(0)
  badge           String?
  rating          Float       @default(0)
  reviewsCount    Int         @default(0)
  // CSS rice-bag art tones (until real photography lands in `images`)
  grainLight      String?
  grainMid        String?
  grainDark       String?
  images          String[] // Cloudinary URLs
  weights         Int[]       @default([1, 5, 10, 25])
  featured        Boolean     @default(false)
  cookingTips     String?
  category        Category?   @relation(fields: [categoryId], references: [id])
  categoryId      String?
  reviews         Review[]
  orderItems      OrderItem[]
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([slug])
  @@index([categoryId])
  @@index([featured])
}

model Order {
  id            String        @id @default(cuid())
  orderNo       String        @unique
  user          User?         @relation(fields: [userId], references: [id])
  userId        String?
  // delivery / customer details (guest checkout supported)
  customerName  String
  email         String
  phone         String
  addressLine   String
  city          String
  district      String?
  notes         String?
  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod @default(COD)
  paymentStatus PaymentStatus @default(PENDING)
  subtotal      Int
  deliveryFee   Int           @default(0)
  total         Int
  tracking      String?
  items         OrderItem[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([userId])
}

model OrderItem {
  id        String   @id @default(cuid())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  product   Product? @relation(fields: [productId], references: [id])
  productId String?
  name      String
  weightKg  Int
  unitPrice Int
  quantity  Int
}

model Review {
  id         String   @id @default(cuid())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  String
  user       User?    @relation(fields: [userId], references: [id])
  userId     String?
  authorName String
  place      String?
  rating     Int
  comment    String?
  adminReply String?
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([productId])
}

model BlogPost {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  excerpt         String?
  content         String
  coverImage      String?
  published       Boolean   @default(false)
  publishedAt     DateTime?
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([slug])
}

model Notification {
  id        String   @id @default(cuid())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String?
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model SpecialRequest {
  id        String   @id @default(cuid())
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  name      String?
  email     String?
  message   String
  status    String   @default("open")
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  actorId   String?
  actorName String?
  action    String
  entity    String?
  detail    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}
